# ─────────────────────────────────────────────
# CIOTX — Environment Configuration
# ─────────────────────────────────────────────
# Copy this file to .env and fill in values.
# .env is in .gitignore — NEVER commit real values.
# ─────────────────────────────────────────────

# ── Database ────────────────────────────────
DB_PASSWORD=change-me-to-a-secure-random-string

# ── Redis ───────────────────────────────────
REDIS_PASSWORD=change-me-to-another-secure-string

# ── URLs ────────────────────────────────────
API_BASE_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000

# ── JWT / Auth ──────────────────────────────
SECRET_KEY=change-me-to-64-char-random-string

# ── LLM Providers (set ANY one — auto-detected) ──
# DeepSeek (recommended — best value)
DEEPSEEK_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Custom OpenAI-compatible endpoint (Ollama, Groq, vLLM, etc.)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# Provider override (auto = detect from keys above)
LLM_PROVIDER=auto
# Fallback chain (try in order if primary fails)
LLM_FALLBACK=deepseek,anthropic,openai

# ── GitHub App ──────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_PATH=

# ── Billing (Razorpay) ──────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Internal ────────────────────────────────
INTERNAL_API_KEY=change-me-to-internal-secret
NODE_ENV=development

# ── Development ─────────────────────────────
DEV_MODE=true
DEV_AUTO_PLAN=pro
