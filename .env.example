# ═══════════════════════════════════════════════════════════
# CIOTX — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in ALL values marked REQUIRED.
# .env is gitignored — NEVER commit real values.
# ═══════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────
APP_NAME=CIOTX
APP_VERSION=0.1.0
API_BASE_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000
DEV_MODE=true
DEV_AUTO_PLAN=pro
LOG_LEVEL=INFO

# ── Database (PostgreSQL) ────────────────────────────
# REQUIRED. Change password in production.
DATABASE_URL=postgresql+asyncpg://ciotx:ciotx_dev_password@postgres:5432/ciotx
DB_PASSWORD=ciotx_dev_password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────
# REQUIRED. Change password in production.
REDIS_URL=redis://:ciotx_dev_redis@redis:6379
REDIS_PASSWORD=ciotx_dev_redis

# ── Authentication & JWT ─────────────────────────────
# REQUIRED. Generate: openssl rand -hex 32
SECRET_KEY=change-me-in-production-to-a-64-char-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
INTERNAL_API_KEY=change-me-to-a-secure-internal-secret

# ── Argon2 Password Hashing ──────────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── LLM Providers ────────────────────────────────────
# Set ANY ONE provider. System auto-detects which is configured.
# Priority: CUSTOM > DeepSeek > OpenAI > Anthropic

# DeepSeek (recommended — best value, $0.14/M input)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=
# Anthropic requires the CIOTX relay in production (API format differs from OpenAI-compatible)

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Custom (Ollama, Groq, vLLM, any OpenAI-compatible endpoint)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# Provider override (auto = detect from keys above)
LLM_PROVIDER=auto
# Fallback chain (tried in order if primary fails)
LLM_FALLBACK=deepseek,anthropic,openai

# ── LLM Tuning ───────────────────────────────────────
LLM_TIMEOUT_SEC=120
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_MAX_LINES_PER_FILE=500
LLM_MAX_FILE_SIZE_MB=10

# ── CIOTX Relay (LLM traffic proxy for privacy) ──────
CIOTX_RELAY_URL=

# ── GitHub Integration ───────────────────────────────
# REQUIRED for GitHub OAuth and repo scanning.
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# REQUIRED for webhook-based PR scanning.
# Create at: https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_PATH=

# ── Billing (Razorpay) ───────────────────────────────
# REQUIRED for payment processing.
# Get from: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Plan Configuration ───────────────────────────────
# TRIAL_DAYS: free trial duration (default 7)
TRIAL_DAYS=7
# TRIAL_SCAN_LIMIT: max scans during trial (default 10)
TRIAL_SCAN_LIMIT=10
# STARTER_SCAN_LIMIT: max scans/month on Starter plan (default 20)
STARTER_SCAN_LIMIT=20
# STARTER_PRICE_MONTHLY: in paise (₹399 = 39900)
STARTER_PRICE_MONTHLY=39900
# STARTER_PRICE_ANNUAL: in paise (₹3,999 = 399900)
STARTER_PRICE_ANNUAL=399900
# PRO_PRICE_MONTHLY: in paise (₹1,499 = 149900)
PRO_PRICE_MONTHLY=149900
# PRO_PRICE_ANNUAL: in paise (₹14,999 = 1499900)
PRO_PRICE_ANNUAL=1499900

# ── Scan Engine ──────────────────────────────────────
# Maximum file size to scan (bytes, default 10MB)
SCAN_MAX_FILE_SIZE=10485760
# Maximum lines per file sent to LLM (default 500)
SCAN_MAX_LINES_PER_FILE=500
# CLI polling interval for PKCE token (seconds)
CLI_PKCE_POLL_INTERVAL=2
# CLI PKCE timeout (seconds)
CLI_PKCE_TIMEOUT=600

# ── Rate Limiting ────────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_SIGNUP=3/hour
RATE_LIMIT_DEFAULT=100/minute

# ── Email (future: Resend / AWS SES) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@ciotx.com
